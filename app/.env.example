# ═══════════════════════════════════════════════════════════
# OpenLoop — Required Environment Variables
# Set ALL of these in Railway → Settings → Variables
# ═══════════════════════════════════════════════════════════

# Database — Railway PostgreSQL plugin provides this
DATABASE_URL=postgresql://postgres:password@localhost:5432/openloop

# Session secret — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-64-char-hex-string

# Redis — Railway Redis plugin (optional, falls back to in-memory)
REDIS_URL=redis://localhost:6379

# ── AI ──────────────────────────────────────────────────────
# Get from https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-xxxx
CEREBRAS_API_KEY_2=csk-xxxx
CEREBRAS_API_KEY_3=csk-xxxx
CEREBRAS_API_KEY_4=csk-xxxx
CEREBRAS_API_KEY_5=csk-xxxx

# Optional extra keys for higher rate limits
# CEREBRAS_API_KEY_2=csk-xxxx
# CEREBRAS_API_KEY_3=csk-xxxx

# ── EMAIL ───────────────────────────────────────────────────
# Get from https://resend.com — verify your domain first
RESEND_API_KEY=re_xxxx
FROM_EMAIL=Loop <loop@yourdomain.com>

# ── PAYMENTS ────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxx
# Get from Stripe Dashboard → Webhooks → Add endpoint
# Endpoint URL: https://YOUR-RAILWAY-URL/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ── SMS / WHATSAPP ──────────────────────────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+15551234567
# Point Twilio webhook to: https://YOUR-RAILWAY-URL/api/webhooks/twilio

# ── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
ADMIN_SECRET=your-admin-secret
# Optional: for cron routes (recalculate-trust, etc.). If set, send x-cron-secret header.
CRON_SECRET=optional-cron-secret

# ═══════════════════════════════════════════════════════════
# RAILWAY DEPLOYMENT — DO THIS IN ORDER
# ═══════════════════════════════════════════════════════════
# 1. Add PostgreSQL plugin in Railway
# 2. Add Redis plugin in Railway (optional)
# 3. Set all env vars above in Railway → Variables
# 4. Deploy — Railway builds automatically from GitHub
# 5. After first deploy, open Railway shell and run:
#    npm run db:migrate
# 6. Add Twilio webhook: YOUR_URL/api/webhooks/twilio
# 7. Add Stripe webhook: YOUR_URL/api/webhooks/stripe
# 8. Run check: npm run check-deploy
# 9. You're live. Invite your first 10 users.
# ═══════════════════════════════════════════════════════════

# Cerebras key list (alternative to individual keys above)
CEREBRAS_API_KEYS=csk-key1,csk-key2,csk-key3

# Internal secrets
ENGAGEMENT_SECRET=optional-engagement-secret
WEBHOOK_SECRET=your-webhook-signing-secret

# NODE_ENV is set automatically by Railway/Next.js
# NODE_ENV=production
