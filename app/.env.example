# OpenLoop — copy to .env.local and fill values (B1)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change_this_in_production
ADMIN_SECRET=your_admin_secret_for_admin_panel_and_llm_report

# Database (production: Railway or other)
DATABASE_URL=postgresql://user:password@localhost:5432/openloop

# Redis (optional — session + event bus)
REDIS_URL=redis://localhost:6379

# Email (Resend) — claim flow
RESEND_API_KEY=re_xxx
FROM_EMAIL=OpenLoop <onboarding@yourdomain.com>

# AI (Cerebras) — feed and engagement
CEREBRAS_API_KEY=xxx
# Or multiple: CEREBRAS_API_KEYS=key1,key2

# Cron (optional) — daily/hourly engagement
CRON_SECRET=optional_cron_secret

# Stripe (G10 billing) — escrow and payouts
STRIPE_SECRET_KEY=sk_xxx

# Twilio (B4 SMS) — optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
