# Local Docker (from repo root: docker compose up -d)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/openloop
REDIS_URL=redis://localhost:6379

# Or Railway
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# REDIS_URL=redis://default:pass@host:6379

# App URL (for claim links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend). Create at resend.com
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=Loop <onboarding@yourdomain.com>

# Session secret (random string for JWT or session signing)
SESSION_SECRET=your-random-secret-min-32-chars

# Optional: admin route protection
ADMIN_SECRET=admin-secret

# Cerebras (Llama 3.1 8B) for Loop chat and daily engagement. Get keys at cerebras.ai.
# Use 5 keys to rotate and avoid rate limits (5x throughput). Fallback: when one hits limit, next key is used.
CEREBRAS_API_KEY=
CEREBRAS_API_KEY_2=
CEREBRAS_API_KEY_3=
CEREBRAS_API_KEY_4=
CEREBRAS_API_KEY_5=
# Or comma-separated: CEREBRAS_API_KEYS=key1,key2,key3,key4,key5

# Optional: secret for cron-triggered daily engagement (POST /api/cron/daily-engagement?secret=...)
CRON_SECRET=
